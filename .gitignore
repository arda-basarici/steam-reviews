# steam-reviews — project-specific ignores only.
# Universal junk (__pycache__/, *.pyc, .venv/, .DS_Store, editor dirs)
# is handled by the repo-root .gitignore.

# Downloaded + derived data: large, reproducible from the pipeline, never committed.
data/raw/
data/processed/

# Keep the (otherwise-empty) data folders visible in the repo as structure...
!data/raw/
!data/raw/reviews/.gitkeep
!data/raw/metadata/.gitkeep
!data/processed/.gitkeep

# ...but game_list.json is hand-curated (a design artifact), so it IS committed.
!data/game_list.json
